// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  userId      Int          @id @default(autoincrement())
  firstName   String
  lastName    String
  email       String
  password    String
  phoneNumber String
  role        Role
  restaurants Restaurant[]
  orders      Order[]
}

model Restaurant {
  restaurantId   Int                  @id @default(autoincrement())
  name           String
  address        String
  description    String
  ownerId        Int
  owner          User                 @relation(fields: [ownerId], references: [userId])
  menuItems      MenuItem[]
  categories     RestaurantCategory[]
  orders         Order[]
  menuCategories MenuCategory[]
}

model MenuItem {
  menuItemId   Int          @id @default(autoincrement())
  name         String
  description  String
  price        Float
  categoryId   Int
  restaurantId Int
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [restaurantId])
  category     MenuCategory @relation(fields: [categoryId], references: [categoryId])
  orderItem    OrderItem?
  ingredients  Ingredient[]
}

model MenuCategory {
  categoryId   Int        @id @default(autoincrement())
  name         String
  restaurantId Int
  menuItemId   Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [restaurantId])
  menuItems    MenuItem[]
}

model RestaurantCategory {
  categoryId   Int        @id @default(autoincrement())
  name         String
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [restaurantId])
}

model Order {
  orderId      Int         @id @default(autoincrement())
  customerId   Int
  restaurantId Int
  totalPrice   Float
  status       String
  createdAt    DateTime
  customer     User        @relation(fields: [customerId], references: [userId])
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [restaurantId])
  orderItems   OrderItem[]
}

model OrderItem {
  orderItemId         Int      @id @default(autoincrement())
  orderId             Int
  menuItemId          Int      @unique
  quantity            Int
  price_at_order_time Float
  order               Order    @relation(fields: [orderId], references: [orderId])
  menuItem            MenuItem @relation(fields: [menuItemId], references: [menuItemId])
}

model Ingredient {
  id        Int        @id @default(autoincrement())
  name      String
  menuItems MenuItem[]
}

enum Role {
  CUSTOMER
  RESTAURANT_OWNER
}
